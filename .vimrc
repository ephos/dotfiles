" https://dougblack.io/words/a-good-vimrc.html
" Editor lines and number settings
set relativenumber
set ruler
set showcmd
set cursorline
set wildmenu

" Folding settings
set foldenable
set foldlevelstart=10
set foldnestmax=10
set foldmethod=syntax
nnoremap <space> za

" Syntax settings
syntax on
colorscheme rdark-terminal
